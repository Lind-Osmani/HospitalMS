<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="1400.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hospitalms.controller.doctor.DoctorFormController">

    <children>
        <VBox layoutX="180.0" layoutY="40.0" spacing="20.0" prefWidth="560.0">

            <children>
                <Label text="Add Doctor"
                       style="-fx-font-size: 26px; -fx-font-weight: bold;" />

                <GridPane hgap="15.0" vgap="15.0">

                    <children>
                        <Label text="First Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <TextField fx:id="firstNameField"
                                   promptText="Enter first name"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="1" />

                        <Label text="Last Name:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <TextField fx:id="lastNameField"
                                   promptText="Enter last name"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="1" />

                        <Label text="Specialization:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <TextField fx:id="specializationField"
                                   promptText="Example: Cardiologist"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="1" />

                        <Label text="Department:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                        <ComboBox fx:id="departmentComboBox"
                                  promptText="Select department"
                                  prefWidth="200.0"
                                  GridPane.rowIndex="3"
                                  GridPane.columnIndex="1" />

                        <Label text="Phone:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                        <TextField fx:id="phoneField"
                                   promptText="Enter phone number"
                                   GridPane.rowIndex="4"
                                   GridPane.columnIndex="1" />

                        <Label text="Email:" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                        <TextField fx:id="emailField"
                                   promptText="Enter email"
                                   GridPane.rowIndex="5"
                                   GridPane.columnIndex="1" />

                        <Label text="Address:" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                        <TextArea fx:id="addressArea"
                                  promptText="Enter address"
                                  prefRowCount="3"
                                  GridPane.rowIndex="6"
                                  GridPane.columnIndex="1" />
                    </children>

                </GridPane>

                <HBox spacing="15.0">
                    <children>
                        <Button text="Save Doctor"
                                prefWidth="130.0"
                                onAction="#handleSaveDoctor" />

                        <Button text="Cancel"
                                prefWidth="100.0"
                                onAction="#handleCancel" />
                    </children>
                </HBox>
            </children>

        </VBox>
    </children>

</AnchorPane>