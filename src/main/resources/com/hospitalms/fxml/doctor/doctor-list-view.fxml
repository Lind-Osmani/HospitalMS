<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="1400.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hospitalms.controller.doctor.DoctorListController">

    <top>
        <AnchorPane prefHeight="70.0" style="-fx-background-color: #2c3e50;">
            <children>
                <Label layoutX="30.0" layoutY="22.0"
                       text="Doctor Management"
                       style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" />
            </children>
        </AnchorPane>
    </top>

    <center>
        <VBox spacing="15.0" style="-fx-padding: 25;">

            <children>
                <HBox spacing="10.0">
                    <children>
                        <TextField fx:id="searchField"
                                   promptText="Search doctor..."
                                   prefWidth="300.0" />

                        <Button text="Search"
                                onAction="#handleSearch" />

                        <Button text="Refresh"
                                onAction="#handleRefresh" />

                        <Button text="Add Doctor"
                                onAction="#handleAddDoctor" />

                        <Button text="Edit Doctor"
                                onAction="#handleEditDoctor" />

                        <Button text="Delete Doctor"
                                onAction="#handleDeleteDoctor" />

                        <Button text="Back to Dashboard"
                                onAction="#handleBackToDashboard" />
                    </children>
                </HBox>

                <TableView fx:id="doctorTable" prefHeight="420.0">
                    <columns>
                        <TableColumn fx:id="idColumn"
                                     text="ID"
                                     prefWidth="70.0" />

                        <TableColumn fx:id="firstNameColumn"
                                     text="First Name"
                                     prefWidth="130.0" />

                        <TableColumn fx:id="lastNameColumn"
                                     text="Last Name"
                                     prefWidth="130.0" />

                        <TableColumn fx:id="specializationColumn"
                                     text="Specialization"
                                     prefWidth="170.0" />

                        <TableColumn fx:id="phoneColumn"
                                     text="Phone"
                                     prefWidth="130.0" />

                        <TableColumn fx:id="emailColumn"
                                     text="Email"
                                     prefWidth="200.0" />
                    </columns>
                </TableView>
            </children>

        </VBox>
    </center>

</BorderPane>