<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hospitalms.controller.appointment.AppointmentListController">

    <top>
        <AnchorPane prefHeight="70.0" style="-fx-background-color: #2c3e50;">
            <children>
                <Label layoutX="30.0"
                       layoutY="22.0"
                       text="Appointment Management"
                       style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" />
            </children>
        </AnchorPane>
    </top>

    <center>
        <VBox spacing="15.0" style="-fx-padding: 25;">
            <children>

                <HBox spacing="10.0">
                    <children>
                        <TextField fx:id="searchField"
                                   promptText="Search appointment..."
                                   prefWidth="220.0" />

                        <Button text="Search"
                                onAction="#handleSearch" />

                        <Button text="Refresh"
                                onAction="#handleRefresh" />

                        <Button text="Add Appointment"
                                onAction="#handleAddAppointment" />

                        <Button text="View Details"
                                onAction="#handleViewDetails" />

                        <Button text="Edit Appointment"
                                onAction="#handleEditAppointment" />

                        <Button text="Delete Appointment"
                                onAction="#handleDeleteAppointment" />

                        <Button text="Back to Dashboard"
                                onAction="#handleBackToDashboard" />
                    </children>
                </HBox>

                <TableView fx:id="appointmentTable"
                           prefHeight="520.0">
                    <columns>
                        <TableColumn fx:id="idColumn"
                                     text="ID"
                                     prefWidth="70.0" />

                        <TableColumn fx:id="patientNameColumn"
                                     text="Patient"
                                     prefWidth="150.0" />

                        <TableColumn fx:id="doctorNameColumn"
                                     text="Doctor"
                                     prefWidth="200.0" />

                        <TableColumn fx:id="dateColumn"
                                     text="Date"
                                     prefWidth="160.0" />

                        <TableColumn fx:id="timeColumn"
                                     text="Time"
                                     prefWidth="120.0" />

                        <TableColumn fx:id="statusColumn"
                                     text="Status"
                                     prefWidth="150.0" />
                    </columns>
                </TableView>

            </children>
        </VBox>
    </center>

</BorderPane>