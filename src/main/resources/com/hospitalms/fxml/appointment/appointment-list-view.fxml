<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hospitalms.controller.appointment.AppointmentListController">

    <top>
        <AnchorPane prefHeight="70.0" style="-fx-background-color: #2c3e50;">
            <children>
                <Label layoutX="30.0" layoutY="22.0" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="Appointment Management" />
            </children>
        </AnchorPane>
    </top>

    <center>
        <VBox spacing="15.0" style="-fx-padding: 25;">
            <children>

                <HBox spacing="10.0">
                    <children>
                        <TextField fx:id="searchField" prefHeight="26.0" prefWidth="211.0" promptText="Search appointment..." />

                        <Button onAction="#handleSearch" text="Search" />

                        <Button onAction="#handleRefresh" text="Refresh" />

                        <Button onAction="#handleAddAppointment" text="Add Appointment" />

                        <Button onAction="#handleEditAppointment" text="Edit Appointment" />

                        <Button onAction="#handleDeleteAppointment" text="Delete Appointment" />

                        <Button onAction="#handleBackToDashboard" text="Back to Dashboard" />
                    </children>
                </HBox>

                <TableView fx:id="appointmentTable" prefHeight="420.0">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="60.0" text="ID" />

                        <TableColumn fx:id="patientNameColumn" prefWidth="150.0" text="Patient" />

                        <TableColumn fx:id="doctorNameColumn" prefWidth="150.0" text="Doctor" />

                        <TableColumn fx:id="dateColumn" prefWidth="110.0" text="Date" />

                        <TableColumn fx:id="timeColumn" prefWidth="90.0" text="Time" />

                        <TableColumn fx:id="reasonColumn" prefWidth="180.0" text="Reason" />

                        <TableColumn fx:id="statusColumn" prefWidth="100.0" text="Status" />
                    </columns>
                </TableView>

            </children>
        </VBox>
    </center>

</BorderPane>
