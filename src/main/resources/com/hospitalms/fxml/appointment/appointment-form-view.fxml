<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="1400.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hospitalms.controller.appointment.AppointmentFormController">

    <children>
        <VBox layoutX="180.0" layoutY="45.0" spacing="20.0" prefWidth="560.0">

            <children>
                <Label text="Add Appointment"
                       style="-fx-font-size: 26px; -fx-font-weight: bold;" />

                <GridPane hgap="15.0" vgap="15.0">

                    <children>
                        <Label text="Patient:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <ComboBox fx:id="patientComboBox"
                                  promptText="Select patient"
                                  prefWidth="260.0"
                                  GridPane.rowIndex="0"
                                  GridPane.columnIndex="1" />

                        <Label text="Doctor:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <ComboBox fx:id="doctorComboBox"
                                  promptText="Select doctor"
                                  prefWidth="260.0"
                                  GridPane.rowIndex="1"
                                  GridPane.columnIndex="1" />

                        <Label text="Date:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <DatePicker fx:id="appointmentDatePicker"
                                    GridPane.rowIndex="2"
                                    GridPane.columnIndex="1" />

                        <Label text="Time:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                        <ComboBox fx:id="appointmentTimeComboBox"
                                  promptText="Select time"
                                  prefWidth="260.0"
                                  GridPane.rowIndex="3"
                                  GridPane.columnIndex="1" />

                        <Label text="Status:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                        <ComboBox fx:id="statusComboBox"
                                  promptText="Select status"
                                  prefWidth="260.0"
                                  GridPane.rowIndex="4"
                                  GridPane.columnIndex="1" />

                        <Label text="Reason:" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                        <TextArea fx:id="reasonArea"
                                  promptText="Enter appointment reason"
                                  prefRowCount="4"
                                  GridPane.rowIndex="5"
                                  GridPane.columnIndex="1" />
                    </children>

                </GridPane>

                <HBox spacing="15.0">
                    <children>
                        <Button text="Save Appointment"
                                prefWidth="150.0"
                                onAction="#handleSaveAppointment" />

                        <Button text="Cancel"
                                prefWidth="100.0"
                                onAction="#handleCancel" />
                    </children>
                </HBox>
            </children>

        </VBox>
    </children>

</AnchorPane>